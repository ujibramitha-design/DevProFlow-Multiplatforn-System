# =====================================================
# SUPABASE CONFIGURATION
# =====================================================

# Supabase Project URL
# Get this from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon/Public Key
# Get this from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (for server-side operations)
# KEEP THIS SECRET! Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# DATABASE CONFIGURATION
# =====================================================

# Main Tables
DATABASE_TABLE_NASABAH=nasabah
DATABASE_TABLE_PROPERTI=properti
DATABASE_TABLE_UNIT=unit
DATABASE_TABLE_APLIKASI_KPR=aplikasi_kpr
DATABASE_TABLE_DOKUMEN=dokumen
DATABASE_TABLE_BANK=bank
DATABASE_TABLE_NOTARIS=notaris
DATABASE_TABLE_TIMELINE=timeline
DATABASE_TABLE_AUDIT_LOG=audit_log

# Database Schema
DATABASE_SCHEMA=public

# Database Connection String
DATABASE_URL=your_database_connection_string

# =====================================================
# DOCUMENT ENGINE SETTINGS
# =====================================================

# Template Paths
DOC_ENGINE_TEMPLATE_PATH=/templates
DOC_ENGINE_OUTPUT_PATH=/tmp/documents

# Supported Formats
DOC_ENGINE_FORMATS=docx,pdf,html

# =====================================================
# PUPPETEER CONFIGURATION (PDF Generation)
# =====================================================

# Puppeteer Executable Path
# Linux: /usr/bin/chromium-browser
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
PUPPETEER_EXECUTABLE_PATH=

# Puppeteer Options
PUPPETEER_HEADLESS=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox

# =====================================================
# IMAGE & QUALITY SETTINGS
# =====================================================

# Image Quality (low, medium, high, ultra)
IMAGE_QUALITY=ultra

# Image DPI (dots per inch)
IMAGE_DPI=300

# PDF Quality
PDF_PRINT_BACKGROUND=true
PDF_PREFER_CSS_PAGE_SIZE=true

# =====================================================
# SECURITY & AUTHENTICATION
# =====================================================

# JWT Secret (for custom auth if needed)
JWT_SECRET=your-jwt-secret-key-change-this-to-random-string

# Session Configuration
SESSION_SECRET=your-session-secret-change-this
SESSION_MAX_AGE=86400

# CORS Settings
CORS_ORIGIN=http://localhost:3000

# =====================================================
# APPLICATION SETTINGS
# =====================================================

# App Environment
NODE_ENV=development

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Base URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# =====================================================
# FEATURE FLAGS
# =====================================================

# Enable Real-time Features
ENABLE_REALTIME=true

# Enable Document Generation
ENABLE_DOC_GENERATION=true

# Enable Email Notifications
ENABLE_EMAIL_NOTIFICATIONS=false

# Enable SMS Notifications
ENABLE_SMS_NOTIFICATIONS=false

# =====================================================
# EXTERNAL SERVICES (Optional)
# =====================================================

# Email Service (if enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@devproflow.com

# SMS Service (if enabled)
SMS_API_KEY=
SMS_API_URL=

# File Storage (if using external storage)
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=documents

# =====================================================
# LOGGING & MONITORING
# =====================================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Enable Debug Mode
DEBUG=false

# Sentry DSN (for error tracking - optional)
SENTRY_DSN=

# =====================================================
# PERFORMANCE
# =====================================================

# Cache TTL (in seconds)
CACHE_TTL=3600

# Max File Upload Size (in MB)
MAX_FILE_SIZE=10

# Request Timeout (in ms)
REQUEST_TIMEOUT=30000
